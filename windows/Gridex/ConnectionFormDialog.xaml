<UserControl
    x:Class="Gridex.ConnectionFormDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Horizontal label-input grid layout matching macOS -->
    <StackPanel Spacing="0" MinWidth="680">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="480">
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Name + Group -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Name"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NameInput" Grid.Column="0"
                             PlaceholderText="My Database" />
                    <TextBlock Grid.Column="1" Text="Group"
                               VerticalAlignment="Center"
                               Margin="12,0,8,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="GroupCombo" Grid.Column="2"
                              MinWidth="160"
                              PlaceholderText="(None)" />
                </Grid>

                <!-- Row 1: Status Color + Tag -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Status color"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="ColorTagPicker" Grid.Column="0"
                                Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Tag"
                               VerticalAlignment="Center"
                               Margin="16,0,8,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="TagCombo" Grid.Column="2"
                              MinWidth="120"
                              SelectedIndex="0">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="Production" />
                        <ComboBoxItem Content="Staging" />
                        <ComboBoxItem Content="Development" />
                        <ComboBoxItem Content="Testing" />
                        <ComboBoxItem Content="Local" />
                    </ComboBox>
                </Grid>

                <!-- Row 2a: MongoDB URI (shown only for MongoDB) -->
                <TextBlock x:Name="UriLabel" Grid.Row="2" Grid.Column="0"
                           Text="URI"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Visibility="Collapsed"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6"
                            Visibility="Collapsed" x:Name="MongoUriSection"
                            Margin="0,0,0,12">
                    <TextBox x:Name="UriInput"
                             PlaceholderText="mongodb://user:pass@host:27017/db  (optional, overrides fields below)" />
                    <TextBox x:Name="MongoOptionsInput"
                             PlaceholderText="authSource=admin&amp;replicaSet=rs0&amp;tls=true  (optional)" />
                </StackPanel>

                <!-- Row 3: Host/Socket + Port -->
                <TextBlock x:Name="HostLabel" Grid.Row="3" Grid.Column="0"
                           Text="Host/Socket"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid x:Name="HostRow" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HostInput" Grid.Column="0"
                             PlaceholderText="127.0.0.1" />
                    <TextBlock Grid.Column="1" Text="Port"
                               VerticalAlignment="Center"
                               Margin="12,0,8,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <NumberBox x:Name="PortInput" Grid.Column="2"
                               Value="5432"
                               SpinButtonPlacementMode="Compact"
                               Minimum="1" Maximum="65535"
                               MinWidth="100" />
                </Grid>

                <!-- Row 4: User + Other Options -->
                <TextBlock x:Name="UserLabel" Grid.Row="4" Grid.Column="0"
                           Text="User"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid x:Name="UserRow" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UserInput" Grid.Column="0"
                             PlaceholderText="postgres" />
                    <Button Grid.Column="1" Content="Other options"
                            Margin="8,0,0,0"
                            VerticalAlignment="Stretch" />
                </Grid>

                <!-- Row 5: Password + Store in keychain -->
                <TextBlock x:Name="PasswordLabel" Grid.Row="5" Grid.Column="0"
                           Text="Password"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid x:Name="PasswordRow" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PasswordInput" Grid.Column="0"
                                 PlaceholderText="Enter password" />
                    <ComboBox Grid.Column="1"
                              Margin="8,0,0,0"
                              SelectedIndex="0"
                              MinWidth="140">
                        <ComboBoxItem Content="Store in keychain" />
                        <ComboBoxItem Content="Don't store" />
                    </ComboBox>
                </Grid>

                <!-- Row 6: Database + SSL mode -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="Database"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid Grid.Row="6" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DatabaseInput" Grid.Column="0"
                             PlaceholderText="mydb" />
                    <TextBlock Grid.Column="1" Text="SSL mode"
                               VerticalAlignment="Center"
                               Margin="12,0,8,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="SslModeInput" Grid.Column="2"
                              MinWidth="130"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Preferred" />
                        <ComboBoxItem Content="Disabled" />
                        <ComboBoxItem Content="Required" />
                        <ComboBoxItem Content="Verify CA" />
                        <ComboBoxItem Content="Verify Identity" />
                    </ComboBox>
                </Grid>

                <!-- Row 7: SSL Keys -->
                <TextBlock x:Name="SslKeysLabel" Grid.Row="7" Grid.Column="0"
                           Text="SSL keys"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel x:Name="SslKeysRow" Grid.Row="7" Grid.Column="1"
                            Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                    <Button Content="Key..." MinWidth="80" />
                    <Button Content="Cert..." MinWidth="80" />
                    <Button Content="CA Cert..." MinWidth="80" />
                    <Button Width="32" Padding="0">
                        <FontIcon Glyph="&#xE738;" FontSize="12" />
                    </Button>
                </StackPanel>

                <!-- Row 8: SQLite File Path (shown only for SQLite) -->
                <TextBlock x:Name="FileLabel" Grid.Row="8" Grid.Column="0"
                           Text="Database File"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Visibility="Collapsed"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid x:Name="SqliteFileSection" Grid.Row="8" Grid.Column="1"
                      Visibility="Collapsed" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathInput" Grid.Column="0"
                             PlaceholderText="path/to/database.db" />
                    <Button Content="Browse..." Grid.Column="1"
                            Margin="8,0,0,0"
                            Click="BrowseFile_Click" />
                </Grid>

                <!-- Row 9: SSH Section (collapsed by default) -->
                <StackPanel x:Name="SshSection" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                            Visibility="Collapsed"
                            Margin="0,4,0,0"
                            Padding="16"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <TextBlock Text="SSH TUNNEL" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="SSH Host"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshHostInput" Grid.Column="0"
                                     PlaceholderText="ssh.example.com" />
                            <TextBlock Grid.Column="1" Text="Port"
                                       VerticalAlignment="Center" Margin="12,0,8,0"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <NumberBox x:Name="SshPortInput" Grid.Column="2"
                                       Value="22" SpinButtonPlacementMode="Compact"
                                       MinWidth="80" />
                        </Grid>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Username"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="SshUserInput" Grid.Row="1" Grid.Column="1"
                                 PlaceholderText="user" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Auth"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox x:Name="SshAuthInput" Grid.Row="2" Grid.Column="1"
                                  HorizontalAlignment="Stretch" SelectedIndex="0"
                                  Margin="0,0,0,10"
                                  SelectionChanged="SshAuth_Changed">
                            <ComboBoxItem Content="Password" />
                            <ComboBoxItem Content="Private Key" />
                            <ComboBoxItem Content="Key + Passphrase" />
                        </ComboBox>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Password"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <PasswordBox x:Name="SshPasswordInput" Grid.Row="3" Grid.Column="1"
                                     PlaceholderText="SSH password" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Key file"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid x:Name="SshKeySection" Grid.Row="4" Grid.Column="1"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshKeyInput" Grid.Column="0"
                                     PlaceholderText="~/.ssh/id_rsa" />
                            <Button Content="Browse..." Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Click="BrowseSshKey_Click" />
                        </Grid>
                    </Grid>
                </StackPanel>

                <!-- Row 10: MCP access mode (per-connection). Decides
                     whether the AI (via MCP server) can see / query /
                     modify this connection. Default Locked, user must
                     opt in explicitly. -->
                <TextBlock Grid.Row="10" Grid.Column="0"
                           Text="MCP access"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid Grid.Row="10" Grid.Column="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="McpModeInput" Grid.Column="0"
                              MinWidth="160" SelectedIndex="0">
                        <ComboBoxItem Content="Locked (AI hidden)" />
                        <ComboBoxItem Content="Read-only (AI can query)" />
                        <ComboBoxItem Content="Read-write (AI can modify w/ approval)" />
                    </ComboBox>
                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Text="You can change this later in MCP Server → Connections." />
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Bottom Action Bar (matches macOS: Over SSH | Save | Test | Connect) -->
        <Border BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,12,0,0"
                Padding="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ToggleButton x:Name="SshToggle" Grid.Column="0"
                              Content="Over SSH"
                              Click="SshToggle_Click" />

                <Button x:Name="SaveButton" Grid.Column="2"
                        Content="Save" Margin="0,0,8,0"
                        Click="SaveButton_Click" />
                <Button x:Name="TestButton" Grid.Column="3"
                        Content="Test" Margin="0,0,8,0"
                        Click="TestButton_Click" />
                <Button x:Name="ConnectButton" Grid.Column="4"
                        Content="Connect"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ConnectButton_Click" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
